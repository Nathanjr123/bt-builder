# Cloud sync (cross-device profiles). Leave blank to run in local-only mode.
# These two values are SAFE to commit/publish — the anon key is a public,
# row-level-security-scoped key designed to ship in client code.
#
# Copy this file to `.env` (or `.env.production`) and fill in your values,
# then rebuild/redeploy. See SETUP_SUPABASE.md for the 2-minute walkthrough.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
